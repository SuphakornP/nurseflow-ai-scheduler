# OpenAI stays server-side. Add the real key when you are ready.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-terra

# Supabase browser-safe settings.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME

# Server-only key. Never prefix this with NEXT_PUBLIC_.
SUPABASE_SECRET_KEY=sb_secret_REPLACE_ME

# Single administrator account. Keep all four values server-side.
# ADMIN_PASSWORD must be 12+ characters; AUTH_SECRET must be a random 32+
# character value. Do not reuse AUTH_SECRET as SOLVER_API_TOKEN.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_DISPLAY_NAME=
AUTH_SECRET=

# Python scheduling service. Use the same 32+ character token in
# services/solver/.env.local.
SOLVER_API_URL=http://127.0.0.1:8000
SOLVER_API_TOKEN=
NEXT_PUBLIC_DEMO_MODE=true
